# Salin file ini menjadi .env.local lalu isi nilainya.
#
# DATABASE_URL : connection string dari dashboard Neon (https://console.neon.tech)
#                pilih "Connection string" -> "Pooled connection" untuk Vercel.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# AUTH_SECRET : kunci acak minimal 32 karakter untuk menandatangani sesi JWT.
#               Buat dengan: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="ganti-dengan-string-acak-minimal-32-karakter"
